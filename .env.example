# Airflow admin user (created by airflow-init)
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=airflow@example.com
AIRFLOW_ADMIN_ROLE=Admin

# Airflow webserver secret key
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-to-a-long-static-secret-key

# MinIO root credentials (also used by Spark/Airflow S3 access)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Data quality report location (inside S3/MinIO bucket)
QUALITY_PREFIX=monitoring/data_quality

# SMTP settings for pipeline alerts (leave blank to disable e-mail sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_SSL=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_ON_SUCCESS=false
